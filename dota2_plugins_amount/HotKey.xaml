<Window x:Class="Dota2NetWorth.HotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置全局快捷键" Height="150" Width="300" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="10" VerticalAlignment="Center">
        <TextBlock Text="请在下方输入框内按下任意组合键：" Margin="0,0,0,10"/>

        <!-- 核心黑科技：用 PreviewKeyDown 拦截并捕获键盘输入 -->
        <TextBox x:Name="KeyTextBox" IsReadOnly="True" PreviewKeyDown="KeyTextBox_PreviewKeyDown" 
                 Padding="5" FontSize="14" Text="点击此处后按下快捷键..." Cursor="Hand"/>

        <Button Content="保存并生效" Margin="0,15,0,0" Padding="5" Click="SaveButton_Click" 
                Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
    </StackPanel>
</Window>